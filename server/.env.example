PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Atlas - https://cloud.mongodb.com (free)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/aluminet?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET=aluminet_jwt_secret_2025_change_this
JWT_REFRESH_SECRET=aluminet_refresh_secret_2025_change_this
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Groq AI - FREE at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Email (optional - Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=AlumiNet <noreply@aluminet.com>
